# ─────────────────────────────────────────────
# HFCX AI Claims Layer — Environment Variables
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_NAME=hfcx-ai-claims
APP_VERSION=1.0.0
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production-32chars

# ── API Server ───────────────────────────────
HOST=0.0.0.0
PORT=8090
WORKERS=4

# ── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://hfcx_ai:password@localhost:5432/hfcx_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ELIGIBILITY_TTL_SECONDS=86400     # FR-EV-001: 24 hour cache for eligibility
REDIS_AGENT_STATE_TTL_SECONDS=86400     # 24 hours for agent memory

# ── Kafka ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=hfcx-ai-claims-group
KAFKA_TOPIC_CLAIMS_VALIDATED=hcx.claims.validated
KAFKA_TOPIC_CLAIMS_ENRICHED=hcx.claims.enriched
KAFKA_TOPIC_DLQ=hcx.claims.ai.dlq
KAFKA_MAX_POLL_RECORDS=100
KAFKA_SESSION_TIMEOUT_MS=30000

# ── LiteLLM Gateway ──────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-internal-hfcx
LITELLM_COORDINATOR_MODEL=ollama/medgemma:27b
LITELLM_CODING_MODEL=ollama/llama3:8b-instruct
LITELLM_ARABIC_MODEL=ollama/bimediX:8x7b
LITELLM_FAST_MODEL=ollama/qwen3:7b
LITELLM_TIMEOUT_SECONDS=30
LITELLM_MAX_RETRIES=3

# ── ChromaDB (RAG vector store) ──────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_EDA_FORMULARY=eda_formulary
CHROMA_COLLECTION_CLINICAL_GUIDELINES=clinical_guidelines

# ── Keycloak (service-to-service auth) ───────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hcx
KEYCLOAK_CLIENT_ID=hfcx-ai-service
KEYCLOAK_CLIENT_SECRET=change-me

# ── HFCX Platform ────────────────────────────
HFCX_REGISTRY_URL=http://localhost:8081/hcx/v0.8/participant/info
HFCX_API_GATEWAY_URL=http://localhost:8082

# ── NDP (National Drug Platform) — FR-MC-003 ─
NDP_API_URL=http://localhost:8083/ndp/v1
NDP_API_KEY=change-me
NDP_TIMEOUT_SECONDS=5

# ── CORS ─────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── MinIO (object storage) ───────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_MODELS=ai-model-weights
MINIO_BUCKET_DOCUMENTS=claim-documents
MINIO_SECURE=false

# ── OpenTelemetry ────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hfcx-ai-claims
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# ── Fraud Detection ──────────────────────────
FRAUD_ISOLATION_FOREST_CONTAMINATION=0.05
FRAUD_HIGH_RISK_THRESHOLD=0.75
FRAUD_MEDIUM_RISK_THRESHOLD=0.45
FRAUD_NETWORK_GRAPH_REFRESH_HOURS=6

# ── Feature Flags ────────────────────────────
ENABLE_FRAUD_AGENT=true
ENABLE_CODING_AGENT=true
ENABLE_ELIGIBILITY_AGENT=true
ENABLE_NECESSITY_AGENT=true
ENABLE_ARABIC_NLP=true
AI_BYPASS_ON_FAILURE=true              # Graceful degradation: bypass AI if layer is down
