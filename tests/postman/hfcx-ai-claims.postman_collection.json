        {
          "name": "POST /agents/fraud/score",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"claim_id\": \"CLAIM-PM-001\",\n  \"provider_id\": \"HCP-EG-CAIRO-001\",\n  \"patient_id\": \"29901011234567\",\n  \"total_amount\": 850.0,\n  \"diagnosis_codes\": [\"J06.9\"],\n  \"procedure_codes\": [\"99213\"],\n  \"claim_date\": \"2026-04-09T10:00:00Z\",\n  \"service_date\": \"2026-04-09T09:00:00Z\",\n  \"claim_type\": \"outpatient\"\n}\n"
            },
            "url": "{{base_url}}/internal/ai/agents/fraud/score"
          }
        },
        {
          "name": "POST /agents/necessity/assess",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"diagnosis_codes\": [\"J06.9\"],\n  \"procedure_codes\": [\"99213\"],\n  \"drug_codes\": [\"EDA-AMOXICILLIN-500\"],\n  \"clinical_notes\": \"Acute URI, fever, sore throat\",\n  \"claim_type\": \"outpatient\",\n  \"total_amount\": 850.0\n}\n"
            },
            "url": "{{base_url}}/internal/ai/agents/necessity/assess"
          }
        }
      ]
    },
    {
      "name": "Memory",
      "item": [
        {
          "name": "POST /memory/store",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_name\": \"fraud\",\n  \"claim_id\": \"CLAIM-PM-001\",\n  \"pattern_key\": \"provider:HCP-EG-CAIRO-001:upcoding\",\n  \"pattern_value\": { \"diagnosis_avg\": 3.2, \"amount_avg\": 1200.0 },\n  \"pattern_type\": \"fraud_signal\",\n  \"confidence\": 0.85\n}\n"
            },
            "url": "{{base_url}}/internal/ai/memory/store"
          }
        },
        {
          "name": "GET /memory/context/{agent}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/internal/ai/memory/context/fraud"
          }
        }
      ]
    },
    {
      "name": "LLM",
      "item": [
        {
          "name": "POST /llm/completion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Summarize: patient J06.9 outpatient visit, antibiotic prescribed.\",\n  \"max_tokens\": 200,\n  \"temperature\": 0.2\n}\n"
            },
            "url": "{{base_url}}/internal/ai/llm/completion"
          }
        }
      ]
    },
    {
      "name": "Drift Feedback",
      "item": [
        {
          "name": "POST /feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correlation_id\": \"{{correlation_id}}\",\n  \"ai_decision\": \"pended\",\n  \"human_decision\": \"approved\",\n  \"ai_score\": 0.55,\n  \"model\": \"coordinator\"\n}\n"
            },
            "url": "{{base_url}}/internal/ai/feedback"
          }
        }
      ]
    }
  ]
}
